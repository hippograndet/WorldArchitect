# Leave unset for local mode: no login, single implicit user (the default).
#
# Set this to enable hosted mode's Clerk sign-in screen. Value comes from your
# Clerk Dashboard -> API Keys -> Publishable key. The server must also be
# configured with matching CLERK_JWKS_URL / CLERK_ISSUER (see DEPLOY.md).
VITE_CLERK_PUBLISHABLE_KEY=

# Local/dev diagnostics only. Shows the Expand run LLM trace viewer when set
# to 1 in a Vite dev build. The server also needs WORLDARCHITECT_LLM_TRACE=1.
VITE_WORLDARCHITECT_DEV_TOOLS=
