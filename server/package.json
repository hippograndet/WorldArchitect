{
  "name": "worldarchitect-server",
  "version": "0.5.0",
  "description": "WorldArchitect Express API server.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "APP_MODE=local DATABASE_URL=postgres://worldarchitect:worldarchitect@localhost:5432/worldarchitect tsx watch src/index.ts",
    "dev:hosted": "APP_MODE=hosted tsx watch --env-file=.env.local src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "test:postgres": "APP_MODE=local DATABASE_URL=postgres://worldarchitect:worldarchitect@localhost:5432/worldarchitect vitest run --no-file-parallelism src/db/postgresMigrations.test.ts src/db/rlsRestrictedRole.test.ts src/tools/context.search.postgres.test.ts src/services/postgresCore.test.ts src/routes/postgresRoutes.test.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "^1.4.7",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.4",
    "@types/pg": "^8.20.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jose": "^6.2.3",
    "jszip": "^3.10.1",
    "nanoid": "^5.1.5",
    "openai": "^4.103.0",
    "pg": "^8.22.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.3",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  }
}
