# Used by `npm run dev:hosted` (via `tsx --env-file=.env.local`).
# Copy this file to .env.local and fill in real values; .env.local is gitignored.
# Not used by plain `npm run dev` (local mode).

APP_MODE=hosted
STORAGE_DRIVER=postgres
DATABASE_URL=postgres://user:password@host:5432/worldarchitect?sslmode=require
PUBLIC_BASE_URL=http://localhost:5173
# Set this to serve the built client from the same server process in production.
# For local `npm run dev:hosted`, leave it blank and run the Vite client separately.
STATIC_DIR=

# From Clerk Dashboard -> API Keys -> "Frontend API URL" / issuer
CLERK_ISSUER=https://<your-instance>.clerk.accounts.dev
CLERK_JWKS_URL=https://<your-instance>.clerk.accounts.dev/.well-known/jwks.json
# Optional. Set only if your Clerk JWTs use a required audience.
CLERK_AUDIENCE=

# Any long random string, used to encrypt stored provider API keys. Required
# in hosted mode. Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PROVIDER_SETTINGS_ENCRYPTION_KEY=

# Hosted-mode operational tuning.
TRUST_PROXY=1
PGPOOL_MAX=5
PGPOOL_IDLE_TIMEOUT_MS=30000
PGPOOL_CONN_TIMEOUT_MS=5000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300

# Optional provider environment overrides. Leave blank to let users configure
# provider keys in the app.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
OLLAMA_BASE_URL=
WORLDARCHITECT_LOCAL_ONLY=

# Local hosted-mode smoke tests only. Do not use in production.
ALLOW_DEV_AUTH_HEADER=
