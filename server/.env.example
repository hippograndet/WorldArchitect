# Used by `npm run dev:hosted` (via `tsx --env-file=.env.local`).
# Copy this file to .env.local and fill in real values; .env.local is gitignored.
# Not used by plain `npm run dev` (local mode).

# From Clerk Dashboard -> API Keys -> "Frontend API URL" / issuer
CLERK_ISSUER=https://<your-instance>.clerk.accounts.dev
CLERK_JWKS_URL=https://<your-instance>.clerk.accounts.dev/.well-known/jwks.json

# Any long random string, used to encrypt stored provider API keys. Required
# in hosted mode. Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PROVIDER_SETTINGS_ENCRYPTION_KEY=
